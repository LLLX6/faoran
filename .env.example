# Runtime
KHADAMATI_ENV=production
HOST=0.0.0.0
PORT=8080
KHADAMATI_PUBLIC_URL=https://lllx6.github.io/Khadamati/
KHADAMATI_ALLOWED_ORIGINS=https://lllx6.github.io
KHADAMATI_SESSION_DAYS=30

# Storage (use a persistent disk in production)
KHADAMATI_DB_PATH=/var/data/khadamati.sqlite3
KHADAMATI_UPLOAD_DIR=/var/data/uploads
KHADAMATI_BACKUP_DIR=/var/data/backups

# Secrets: generate unique values; never commit real secrets
KHADAMATI_ADMIN_CODE=
KHADAMATI_OTP_PEPPER=
KHADAMATI_OTP_TTL_MINUTES=5
KHADAMATI_OTP_MAX_ATTEMPTS=5
KHADAMATI_OTP_HOURLY_LIMIT=5

# OTP delivery. Production OTP remains unavailable until a delivery provider is wired.
# KHADAMATI_DEV_OTP_CODE is development-only and is ignored as a fixed code in production.
KHADAMATI_DEV_OTP_CODE=

# Payment adapter. Keep gateway=manual until checkout and webhook credentials are ready.
KHADAMATI_PAYMENT_GATEWAY=manual
KHADAMATI_PAYMENT_CHECKOUT_URL=
KHADAMATI_PAYMENT_WEBHOOK_SECRET=

# Official WhatsApp Cloud API (optional)
WHATSAPP_API_VERSION=v21.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# Web Push (optional)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@khadamatiapp.com
